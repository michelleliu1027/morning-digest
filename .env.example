# --- Slack ---
# Bot token from your new Slack app (OAuth & Permissions page). Starts with xoxb-
# v1 only needs this one token, with the chat:write scope (to DM you the digest).
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Your own Slack user ID (looks like U01ABC2DEF). The digest gets DM'd here.
# Find it: Slack profile -> ... -> Copy member ID
MY_SLACK_USER_ID=U01ABC2DEF

# --- GitHub ---
# Repos to scan for PRs that need your attention (review-requested, assigned, authored-open).
# Comma-separated "owner/repo". Leave blank to use gh's default search across all your repos.
GITHUB_REPOS=

# --- Claude ---
# Path to the claude CLI (usually just "claude" if it's on PATH).
CLAUDE_BIN=claude
# Model alias or full id. Defaults to opus.
CLAUDE_MODEL=opus

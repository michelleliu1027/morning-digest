# --- Slack ---
# Bot token from your Slack app (OAuth & Permissions). Starts with xoxb-.
# Needs chat:write + im:write — used to DM you the digest.
SLACK_MORNING_TASKS_DIGEST_BOT_TOKEN=xoxb-your-bot-token

# User token (xoxp-) with the search:read User Token Scope. Required to READ your
# @mentions + DMs (the Slack source). Bot tokens cannot search; this must be a
# user token. Leave blank to skip the Slack source entirely.
SLACK_MORNING_TASKS_DIGEST_USER_TOKEN=xoxp-your-user-token

# Your own Slack user ID (looks like U01ABC2DEF). The digest gets DM'd here.
# Find it: Slack profile -> ... -> Copy member ID
MY_SLACK_USER_ID=U01ABC2DEF

# Optional: your name, used to personalize the digest prompt (e.g. "Alex's
# morning to-do digest"). Leave blank to keep it generic ("your ... digest").
MY_NAME=

# --- GitHub ---
# Repos to scan for PRs that need your attention (review-requested, assigned, authored-open).
# Comma-separated "owner/repo". Leave blank to use gh's default search across all your repos.
GITHUB_REPOS=

# --- Claude ---
# Path to the claude CLI (usually just "claude" if it's on PATH).
CLAUDE_BIN=claude
# Model alias or full id. Defaults to opus.
CLAUDE_MODEL=opus
